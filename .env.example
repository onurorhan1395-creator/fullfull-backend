# --- Sunucu ---
PORT=4000
NODE_ENV=production
API_KEY=degistir-bu-cok-gizli-bir-anahtar-olsun

# --- Veritabani (PostgreSQL) ---
# Railway/Render/Supabase gibi servisler bu URL'i otomatik verir.
DATABASE_URL=postgres://kullanici:sifre@localhost:5432/fullfull_panel

# --- E-posta (SMTP) ---
# Gmail kullanacaksan: "Uygulama Sifresi" (App Password) olusturman gerekir,
# normal Gmail sifren calismaz. Kurumsal SMTP de kullanabilirsin (Office365 vb).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bayi.bildirim@gmail.com
SMTP_PASS=uygulama-sifresi-buraya
SMTP_FROM="Full+Full Panel <bayi.bildirim@gmail.com>"

# --- Departman e-postalari (varsayilan; DB'deki departmanlar tablosundan da yonetilebilir) ---
KASKO_DEPARTMAN_EMAIL=kasko@bayi.com
KORUMA_DEPARTMAN_EMAIL=koruma@bayi.com

# --- Dosya yukleme ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
